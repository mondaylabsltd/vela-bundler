{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["@cloudflare/workers-types", "node"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,

    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "shared",
    "worker",
    "scripts",
    "*.config.ts",
    "vitest.workspace.ts"
  ],
  // tests/ (the shared-logic vitest suite) is validated at runtime by vitest, not by tsc —
  // matching the prior Deno gate, which type-checked only deno/main.ts's import graph (shared/)
  // and never the test files. Shipping code (shared/, worker/) IS strictly type-checked here.
  "exclude": ["node_modules", "tests"]
}
