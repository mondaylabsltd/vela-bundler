{
  "private": true,
  "type": "module",
  "name": "vela-bundler",
  "description": "Cloudflare Workers ERC-4337 / ERC-7769 multi-chain bundler (EntryPoint v0.7)",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:node": "vitest run --project node",
    "test:worker": "vitest run --project workers",
    "generate-bytecode": "node --experimental-strip-types scripts/generate-bytecode.ts"
  },
  "dependencies": {
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.41",
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "~2.1.0",
    "wrangler": "^3.100.0"
  }
}
