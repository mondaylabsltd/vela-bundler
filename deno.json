{
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --env --watch deno/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read --env --no-lock deno/main.ts",
    "test": "deno test -A",
    "build": "deno run --allow-read --allow-write scripts/build-html.ts",
    "lint": "deno lint && deno check deno/main.ts",
    "e2e": "deno run --allow-net --allow-env --allow-read --allow-run --env scripts/e2e.ts",
    "generate-bytecode": "deno run --allow-read --allow-write scripts/generate-bytecode.ts",
    "deploy": "deno run --allow-read --allow-write --allow-run=ssh,tar --allow-env=HOME,USER,XDG_CONFIG_HOME,TERM,NO_COLOR --allow-net scripts/deploy.ts",
    "deploy:status": "deno run --allow-read --allow-write --allow-run=ssh,tar --allow-env=HOME,USER,XDG_CONFIG_HOME,TERM,NO_COLOR --allow-net scripts/deploy.ts status",
    "deploy:rollback": "deno run --allow-read --allow-write --allow-run=ssh,tar --allow-env=HOME,USER,XDG_CONFIG_HOME,TERM,NO_COLOR --allow-net scripts/deploy.ts rollback"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "marked": "npm:marked@15",
    "viem": "npm:viem@2.52.2",
    "viem/chains": "npm:viem@2.52.2/chains",
    "viem/accounts": "npm:viem@2.52.2/accounts",
    "viem/tempo": "npm:viem@2.52.2/tempo"
  },
  "lint": {
    "rules": {
      "exclude": [
        "require-await"
      ]
    }
  },
  "test": {
    "include": [
      "tests/"
    ]
  },
  "lock": false,
  "nodeModulesDir": "none",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true
  }
}
