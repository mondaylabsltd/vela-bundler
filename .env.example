# Required
CHAIN_ID=1
ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# RPC priority: USER_RPC_URLS > RPC_URL > auto-resolved from chain registry.
# Only chains listed at https://ethereum-data.awesometools.dev/ are supported.
#
# User-provided RPCs (comma-separated, highest priority):
# USER_RPC_URLS=https://my-private-rpc.example.com,https://backup-rpc.example.com
#
# Operator override (e.g. for local dev):
# RPC_URL=http://localhost:8545
#
# Per-request override: pass X-Rpc-Url header (highest priority of all, per-request only).

# --- Private prepaid bundler ---

# High-entropy operator secret for deterministic EOA derivation.
# NEVER share, log, or expose this value. Minimum 32 characters.
OPERATOR_SECRET=0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# Active key version (new deposit addresses use this version).
ACTIVE_KEY_VERSION=1

# Old key versions (comma-separated) — draining, no new ops accepted.
# DRAINING_KEY_VERSIONS=

# Rate limit per IP per minute.
API_RATE_LIMIT_PER_MINUTE=60

# Balance reserve multiplier (require Nx expected cost in EOA balance).
BALANCE_RESERVE_MULTIPLIER=2

# Legacy fields — used as fallback in testing/non-private mode.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
BENEFICIARY_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# Server
PORT=3300
HOST=0.0.0.0

# Bundling
BUNDLING_MODE=auto
MAX_BUNDLE_SIZE=10
MAX_BUNDLE_GAS=5000000
MIN_PRIORITY_FEE_PER_GAS=1000000000

# Profitability
MIN_PROFIT_MARGIN_BPS=2000
TARGET_PROFIT_MARGIN_BPS=3500
HIGH_RISK_MARGIN_BPS=5000

# Gas
# Leave USE_EIP1559 unset to auto-detect from chain registry.
# USE_EIP1559=true
BASE_FEE_MULTIPLIER=1.25
BUNDLER_TIP_GWEI=1.5

# Mode — set to "testing" to enable debug_* RPCs.
MODE=production

# Auto-bundle interval in ms (only when BUNDLING_MODE=auto).
AUTO_BUNDLE_INTERVAL_MS=10000
