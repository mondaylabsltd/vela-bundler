# === Required ===
# 32+ byte hex secret. ALL user EOA private keys and the treasury key derive from this —
# generate from a CSPRNG (e.g. `openssl rand -hex 32`) and store it only in a secret manager.
OPERATOR_SECRET=0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# The treasury address is DERIVED from OPERATOR_SECRET (same on all chains) — it is NOT read
# from the environment. `GET /v1/treasury` returns it.

# === Optional (all have sensible defaults) ===

# Alchemy API key — enables preferred RPCs on supported chains.
# ALCHEMY_API_KEY=

# Old operator secrets for deriving rotated EOAs after a secret rotation (comma-separated).
# OLD_OPERATOR_SECRETS=

# === Monitoring / alerting (STRONGLY recommended for production) ===
# Operational alerts via Telegram. When BOTH are set, the bundler pages the operator on
# EVERY intervention-worthy state: money stuck (mempool/pending/EOA), broadcast failures,
# treasury low/unreadable, sponsorship failing, recurring code errors, unhandled exceptions,
# plus a periodic "alive" heartbeat (silence past ~6h = assume dead). Unset = alerts
# DISABLED (loud startup warning + `alerting: "disabled"` in /health).
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# TELEGRAM_CHAT_ID=123456789
# Treasury alert FLOOR (defaults shown): native 0.02 ETH, Tempo 0.5 pathUSD (6-dec).
# On native chains the effective threshold is automatically RAISED to the sponsor's dynamic
# fail-closed floor (TREASURY_FLOOR + worst-case sponsor amount at the current gas price),
# so the low-treasury alert always fires BEFORE sponsorship starts failing closed.
# TREASURY_ALERT_THRESHOLD_WEI=20000000000000000
# TREASURY_ALERT_THRESHOLD_PATHUSD=500000

# Client IPs exempt from rate limiting (comma-separated) — set this to the trading bot's
# egress IP(s) so its op submissions + receipt polls can never self-throttle.
# RATE_LIMIT_ALLOWLIST=

