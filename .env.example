# === Required ===
OPERATOR_SECRET=0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef
TREASURY_ADDRESS=0xYourTreasuryAddressHere

# === Optional (all have sensible defaults) ===

# Chain (default: Ethereum mainnet)
# CHAIN_ID=1

# RPC override (auto-resolved from https://ethereum-data.awesometools.dev/ by default)
# USER_RPC_URLS=https://my-rpc.example.com
# RPC_URL=http://localhost:8545

# Old operator secrets for sweeping after secret rotation (comma-separated)
# OLD_OPERATOR_SECRETS=

# Sweep: every N bundles per EOA (default: 30). 0 = disabled.
# SWEEP_INTERVAL=30

# Server (default: 0.0.0.0:3300)
# PORT=3300
# HOST=0.0.0.0
