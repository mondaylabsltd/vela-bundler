# Remote Iggy and Redis endpoints. Iggy needs only this one connection setting: the consumer and
# provisioner inherit it automatically. Keep credentials URL-encoded when they contain symbols.
VELA_RELAY_IGGY_URL=iggy+tcp://iggy:replace-with-password@iggy.example.com:3000?reconnection_retries=5&reconnection_interval=1s&reestablish_after=5s&heartbeat_interval=3s&nodelay=true
VELA_RELAY_REDIS_URL=redis://:replace-with-password@redis.example.com:6379

# The consumer/executor is enabled by default. It needs the relayer secret and one RPC source.
OPERATOR_SECRET=replace-with-the-operator-secret
ALCHEMY_API_KEY=replace-with-an-alchemy-api-key

# Optional alternatives and deployment settings:
# VELA_RELAY_EXECUTOR_ENABLED=false
# VELA_RELAY_EXECUTOR_RPC_URLS={"42161":"https://your-rpc.example"}
# VELA_RELAY_PORT=4567
# VELA_RELAY_IMAGE=docker.io/your-dockerhub-username/vela-relay:v1.2.3
