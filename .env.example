# === Required ===
# 32+ byte hex secret. ALL user EOA private keys and the treasury key derive from this —
# generate from a CSPRNG (e.g. `openssl rand -hex 32`) and store it only in a secret manager.
OPERATOR_SECRET=0xdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeefdeadbeef

# The treasury address is DERIVED from OPERATOR_SECRET (same on all chains) — it is NOT read
# from the environment. `GET /v1/treasury` returns it.

# === Optional (all have sensible defaults) ===

# Alchemy API key — enables preferred RPCs on supported chains.
# ALCHEMY_API_KEY=

# Old operator secrets for deriving rotated EOAs after a secret rotation (comma-separated).
# OLD_OPERATOR_SECRETS=

# Server bind (Deno runtime only; default 0.0.0.0:3300).
# PORT=3300
# HOST=0.0.0.0

# === Monitoring / alerting (optional) ===
# Treasury-balance alerts via Telegram. When BOTH are set, the health loop sends a
# de-duplicated alert (once per 30 min per chain) whenever the treasury balance on an
# active chain drops below the threshold. Unset = alerts disabled (no-op).
# TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# TELEGRAM_CHAT_ID=123456789
# Alert thresholds (defaults shown): native 0.02 ETH, Tempo 0.5 pathUSD (6-dec).
# TREASURY_ALERT_THRESHOLD_WEI=20000000000000000
# TREASURY_ALERT_THRESHOLD_PATHUSD=500000
