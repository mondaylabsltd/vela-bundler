# Remote Iggy and Redis endpoints. Iggy needs only this one connection setting: the consumer and
# provisioner inherit it automatically. Keep credentials URL-encoded when they contain symbols.
VELA_RELAY_IGGY_URL=iggy+tcp://iggy:replace-with-password@iggy.example.com:3000?reconnection_retries=5&reconnection_interval=1s&reestablish_after=5s&heartbeat_interval=3s&nodelay=true
VELA_RELAY_REDIS_URL=redis://:replace-with-password@redis.example.com:6379

# The consumer/executor is enabled by default. It needs only the relayer secret; trusted RPCs
# resolve automatically from Vela's controlled chain directory.
OPERATOR_SECRET=replace-with-the-operator-secret

# Optional RPC override and deployment settings. Alchemy is automatically preferred when set.
# ALCHEMY_API_KEY=replace-with-an-alchemy-api-key
# VELA_RELAY_EXECUTOR_ENABLED=false
# VELA_RELAY_EXECUTOR_RPC_URLS={"42161":"https://your-rpc.example"}
# Relayer float target defaults to 5× the next bundle prefund. If Binance has a native USD
# price, each automatic native top-up is capped at $20; otherwise the static wei cap below applies.
# VELA_RELAY_EXECUTOR_FLOAT_COST_MULTIPLIER=5
# Fallback cap for chains whose native asset has no USD price: 10 native tokens by default.
# VELA_RELAY_EXECUTOR_TOP_UP_MAX_WEI=10000000000000000000
# Amount retained after a treasury top-up for its next transfer: 0.0001 native by default.
# VELA_RELAY_EXECUTOR_TREASURY_FLOOR_WEI=100000000000000
# Optional executor-problem alerts. Set both values; identical chain/stage/reason alerts are
# suppressed for 30 minutes by default across every Relay worker and instance.
# TELEGRAM_BOT_TOKEN=replace-with-a-bot-token
# TELEGRAM_CHAT_ID=replace-with-a-chat-id
# VELA_RELAY_TELEGRAM_ALERT_COOLDOWN_SECS=1800
# VELA_RELAY_PORT=4567
# VELA_RELAY_IMAGE=docker.io/your-dockerhub-username/vela-relay:v1.2.3
